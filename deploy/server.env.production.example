NODE_ENV=production
HOST=127.0.0.1
PORT=3001
CORS_ORIGIN=https://www.altos-experts.fr,https://altos-experts.fr
DATABASE_URL=postgres://altos:CHANGE_ME@127.0.0.1:5432/altos
DOCUMENTS_PRIVATE_DIR=/var/lib/altos/documents/private

# SMTP interne pour recevoir les nouveaux micro-audits.
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@altos-experts.fr
SMTP_PASS=CHANGE_ME
NOTIFICATION_FROM=ALTOS <hello@altos-experts.fr>
NOTIFICATION_TO=hello@altos-experts.fr

# Long secret aleatoire pour signer les sessions admin.
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
