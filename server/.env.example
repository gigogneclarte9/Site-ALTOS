NODE_ENV=development
HOST=127.0.0.1
PORT=3001
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
DATABASE_URL=postgres://altos:altos_dev_password@127.0.0.1:15432/altos
DOCUMENTS_PRIVATE_DIR=./storage/private

# Optional: internal notification when a micro-audit is submitted.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM=
NOTIFICATION_TO=

# Required in production. Use a long random value.
ADMIN_SESSION_SECRET=change-me-with-a-long-random-secret
