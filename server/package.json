{
  "name": "altos-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:cleanup-test-data": "tsx src/db/cleanup-test-data.ts",
    "admin:create": "tsx src/admin/create-user.ts",
    "test:smoke": "tsx src/test/smoke.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jspdf": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
